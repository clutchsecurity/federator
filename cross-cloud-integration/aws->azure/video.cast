[0.000, "o", "\r\n\u001b[1m  # aws_iam_instance_profile.ec2_federation_profile\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_iam_instance_profile\" \"ec2_federation_profile\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m arn         = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m create_date = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name        = \"aws-to-azure-ec2-federation-profile\"\r\n      \u001b[32m+\u001b[0m\u001b[0m name_prefix = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m path        = \"/\"\r\n      \u001b[32m+\u001b[0m\u001b[0m role        = \"aws-to-azure-ec2-federation-role\"\r\n      \u001b[32m+\u001b[0m\u001b[0m tags_all    = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m unique_id   = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # aws_iam_outbound_web_identity_federation.this\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_iam_outbound_web_identity_federation\" \"this\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m issuer_identifier = (known after apply)\r\n    }\r\n"]
